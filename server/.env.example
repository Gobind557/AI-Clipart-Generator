# openai | stability
IMAGE_PROVIDER=openai

OPENAI_API_KEY=

# Stability (when IMAGE_PROVIDER=stability)
STABILITY_API_KEY=
# Engine id from https://platform.stability.ai/ — must match your plan (SDXL example below).
STABILITY_ENGINE_ID=stable-diffusion-xl-1024-v1-0

# Upstash (or other TLS Redis): use the full REST/TLS URL from the dashboard (rediss://…).
# BullMQ needs this exact variable name. On the same Railway service set START_WORKER=true.
REDIS_URL=
# Required when REDIS_URL is set — otherwise jobs sit in Redis and never call OpenAI/Stability.
START_WORKER=false

