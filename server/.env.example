# openai | stability
IMAGE_PROVIDER=openai

OPENAI_API_KEY=

# Stability (when IMAGE_PROVIDER=stability)
STABILITY_API_KEY=
# Engine id from https://platform.stability.ai/ — must match your plan (SDXL example below).
STABILITY_ENGINE_ID=stable-diffusion-xl-1024-v1-0

# Upstash: paste the rediss:// URL from the Redis console (TLS).
REDIS_URL=
# Required when REDIS_URL is set so queued jobs are processed (same process is OK).
START_WORKER=false

